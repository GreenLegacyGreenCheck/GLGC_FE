# 이 파일을 복사해 .env.local 로 만들고 실제 값을 채워주세요.
# 브라우저에 노출되어도 되는 값은 NEXT_PUBLIC_ 접두사를 붙입니다.

# 고지서 OCR(POST {base}/ocr/bill)을 비롯한 백엔드(Nest.js) API 주소.
# NEXT_PUBLIC_API_BASE_URL=

# 카카오 로그인 (Kakao Developers > 내 애플리케이션 > 앱 키의 REST API 키)
# NEXT_PUBLIC_KAKAO_CLIENT_ID=
# NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/login/kakao/callback

# Google 로그인 (Google Cloud Console > OAuth 클라이언트 ID)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/login/google/callback
